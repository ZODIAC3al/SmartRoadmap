# ── App ──────────────────────────────────────────
NODE_ENV=development
PORT=3000
# Comma-separated allow-list used for CORS (NOT '*')
FRONTEND_URL=http://localhost:3001

# ── Database ─────────────────────────────────────
# Required. The app fails to boot without it (no silent localhost fallback).
MONGODB_URI=mongodb://localhost:27017/smartroadmap

# ── Auth (required, min 32 chars, no fallback secrets in code) ────
JWT_SECRET=change_me_openssl_rand_base64_32_at_least_32_chars
JWT_EXPIRY=15m
JWT_REFRESH_SECRET=change_me_another_secret_at_least_32_characters
JWT_REFRESH_EXPIRY=30d
BCRYPT_ROUNDS=12

# Google Sign-In (server verifies the ID token against this audience)
GOOGLE_CLIENT_ID=

# ── Mock mode ────────────────────────────────────
# Explicit opt-in for offline development. REJECTED when NODE_ENV=production.
MOCK_MODE=true
# Seed demo jobs/notifications (auto-on outside production)
SEED_DEMO_CONTENT=true

# ── OpenAI ───────────────────────────────────────
OPENAI_API_KEY=
OPENAI_MODEL_SMART=gpt-4o
OPENAI_MODEL_FAST=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# ── Qdrant (vector search; RAG falls back to mocks if unset) ──
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=

# ── PayPal (required in production; webhook is the source of truth) ──
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_WEBHOOK_ID=
PAYPAL_MODE=sandbox

# ── Cloudinary (image uploads) ───────────────────
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ── Email (required in production — password resets must not vanish) ──
RESEND_API_KEY=
EMAIL_FROM=noreply@smartroadmap.io

# ── Rate limiting ────────────────────────────────
THROTTLE_TTL=60000
THROTTLE_LIMIT=100
# Login/register/google budget per minute per IP. Keep this at 5 in production.
AUTH_THROTTLE_LIMIT=5
MAX_UPLOAD_BYTES=5242880
